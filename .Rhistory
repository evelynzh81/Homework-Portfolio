library(faraway)
library(caret)
library(math3190package)
df=pima
df = df |>
rename(result=test)|>
mutate(result = as.factor(result))
y=df$result
X = df[,c('pregnant','glucose','diastolic','triceps','insulin','bmi','diabetes','age')]
set.seed(7)
test_index = createDataPartition(y, times = 1,p=0.2, list=FALSE)
test = df[test_index,]
train = df[-test_index,]
model <- glm(result ~ glucose + bmi, data = train, family = binomial)
classifier_plot(model, data=train)
confusionMatrix(predict(model, type="response"), test$result)$table
length(predict(model, type="response"))
length(test$result)
confusionMatrix(predict(model, type="response", test$result), test$result)$table
library(naivebayes)
nb = naive_bayes(result ~ glucose + bmi, data= train)
head(predict(nb,type='prob'))|>round(3)
nbk = naive_bayes(result ~ glucose + bmi, data = train, usekernel=TRUE)
yhat = predict(nb, newdata=test, type="class")
confusionMatrix(yhat, test$result)$table
confusionMatrix(predict(model, newdata = test, type="response"), test$result)$table
length(predict(model, newdata = test, type="response"))
predict(model, newdata = test, type="response")
length(predict(model, newdata = test, type="response"))
length(test$result)
confusionMatrix(predict(model, newdata=test, type="response"), test$result)$table
yhat = predict(nb, newdata=test, type="class")
confusionMatrix(yhat, test$result)$table
yhat = predict(model, newdata = test, type="response")
confusionMatrix(yhat, test$result)$table
yhat = predict(model, newdata = test, type="response", positive = '1')
confusionMatrix(yhat, test$result)$table
yhat = predict(nb, newdata=test, type="class", positive = "1")
confusionMatrix(yhat, test$result)$table
library(e1071)
svm_mod = svm(result ~ glucose + bmi)
