histogramMaker = function(values,x,y,title,bins = 30){
#makes a bar chart for the States
df = data.frame(values)
ggplot(df, aes(x = values)) +
geom_histogram(color = "black", fill = "steelblue", bins = bins, na.rm = TRUE) +
lims(x = c(min(values)-0.05, max(values)+0.05)) +
labs(x = x,
y = y,
title = title) +
theme(axis.title = element_text(size = 16),
axis.text = element_text(size = 12),
plot.title = element_text(size = 18, face = "bold"))
}
barchartMaker = function(data, x_var, fill_color = "steelblue", title = NULL) {
ggplot(data, aes(x = {{ x_var }})) +
geom_bar(fill = fill_color) +
labs(
title = title,
x = substitute(x_var),
y = "Count"
) +
theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust=1),
legend.position = "None")
}
#| label: check how data is distribuited
histogramMaker(Chargeoff_Data_Numeric$Effective_Annual_Interest_Rate ,"Effective annual rate","Frequency","")
histogramMaker(Chargeoff_Data_Numeric$Time_To_Maturity ,"Time to Maturity","Frequency","")
histogramMaker(Chargeoff_Data_Numeric$Time_to_Charge_Off ,"Time_to_Charge_Off","Frequency","")
histogramMaker(Chargeoff_Data_Numeric$Monthly_Payment ,"Monthly Payment","Frequency","")
histogramMaker(Chargeoff_Data_Numeric$Original_Loan_Amount ,"Loan amount","Frequency","")
barchartMaker(Chargeoff_Data_Numeric, Is_Censored ,title = "Application codes")
barchartMaker(Chargeoff_Data_Numeric, Application_Code ,title = "Application codes")
barchartMaker(Chargeoff_Data_Numeric, Product ,title = "Types of loans")
#| label: check linearity
chargeoffNoCategorical = select(Chargeoff_Data_Numeric, Effective_Annual_Interest_Rate, Monthly_Payment, Time_To_Maturity, Original_Loan_Amount, Is_Censored, Time_to_Charge_Off)
ggpairs(chargeoffNoCategorical)
#| label: check linearity
chargeoffNoCategorical = select(Chargeoff_Data_Numeric, Effective_Annual_Interest_Rate, Monthly_Payment, Time_To_Maturity, Original_Loan_Amount, Is_Censored, Time_to_Charge_Off)
ggpairs(chargeoffNoCategorical)
#| label: check log linearity
logChargeoff = mutate(Chargeoff_Data_Numeric, Monthly_Payment = log(Monthly_Payment), Original_Loan_Amount = log(Original_Loan_Amount), Effective_Annual_Interest_Rate = log(Effective_Annual_Interest_Rate))
#| label: check log linearity
logChargeoff = mutate(Chargeoff_Data_Numeric, Monthly_Payment = log(Monthly_Payment), Original_Loan_Amount = log(Original_Loan_Amount), Effective_Annual_Interest_Rate = log(Effective_Annual_Interest_Rate))
chargeoffNoCategorical = select(logChargeoff, Effective_Annual_Interest_Rate, Monthly_Payment, Time_To_Maturity, Original_Loan_Amount, Time_to_Charge_Off)
ggpairs(chargeoffNoCategorical)
