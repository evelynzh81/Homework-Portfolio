# Predictions using k_pcr components
pca_pred <- predict(pca_model, test_set)[,,3]
# Actual values
y_test <- test_set$l_med_house_val
# Number of observations and predictors
n <- length(y_test)
p <- k_pcr
p <- 3
# RMSE
rmse_pcr <- sqrt(sum((y_test - pcr_pred)^2) / (n - p - 1))
# RMSE
rmse_pcr <- sqrt(sum((y_test - pca_pred)^2) / (n - p - 1))
rmse_pcr
